<%= render "shared/molecules/page_header",
  title: t("courses.index.title"),
  description: t("courses.index.description", tenant: current_tenant.name),
  wrapper_class: "mx-auto max-w-7xl px-4 pt-12 sm:px-6 lg:px-8",
  title_tag: :h1,
  title_class: "app-text app-text--strong text-4xl font-black tracking-tight sm:text-5xl",
  description_class: "app-text app-text--body mt-4 max-w-2xl text-base leading-7" %>

<%= form_with url: tenant_courses_path(tenant_slug: current_tenant.slug), method: :get, scope: :filters, class: "mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8" do |form| %>
  <div class="space-y-8">
    <section class="app-surface app-surface--card p-6">
      <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
        <%= render "shared/molecules/form_field",
          form: form,
          field: :query,
          type: :search_field,
          label: t("courses.index.search.label"),
          description: t("courses.index.search.description"),
          input_html: {
            value: @filters[:query],
            placeholder: t("courses.index.search.placeholder")
          } %>

        <div class="flex flex-wrap items-center gap-3">
          <%= render "shared/atoms/button", text: t("courses.index.search.submit"), type: :submit, class_name: "w-full justify-center sm:w-auto" %>
        </div>
      </div>
    </section>

    <div class="grid gap-8 lg:grid-cols-[18rem_minmax(0,1fr)]">
      <aside class="app-surface app-surface--card p-6">
        <h2 class="app-text app-text--strong text-lg font-bold"><%= t("courses.index.filters.title") %></h2>

        <div class="mt-6 space-y-5">
          <%= render "shared/molecules/select_field",
            form: form,
            field: :sort,
            label: t("courses.index.filters.sort_label"),
            choices: @sort_filter_choices,
            options: {
              selected: @filters[:sort]
            } %>
        </div>

        <div class="mt-6 flex flex-col gap-3">
          <%= render "shared/atoms/button", text: t("courses.index.filters.apply"), type: :submit, class_name: "w-full justify-center" %>
        </div>
      </aside>

      <section>
        <div class="flex items-center justify-between gap-4">
          <div>
            <h2 class="app-text app-text--strong text-2xl font-black tracking-tight"><%= t("courses.index.results.title") %></h2>
            <p class="app-text app-text--body mt-2 text-sm"><%= t("courses.index.results.description", count: @total_count) %></p>
          </div>
        </div>

        <% if @courses.any? %>
          <div class="mt-6 grid gap-6 xl:grid-cols-2">
            <% @courses.each do |course| %>
              <%= render "shared/organisms/tenant_course_card",
                course: course,
                path: tenant_course_path(tenant_slug: current_tenant.slug, id: course[:slug]),
                cta_text: t("courses.index.cta") %>
            <% end %>
          </div>
        <% else %>
          <div class="app-surface app-surface--empty mt-6 p-10 text-center">
            <p class="app-text app-text--strong text-base font-semibold"><%= t("courses.index.empty_title") %></p>
            <p class="app-text app-text--body mt-2 text-sm leading-6"><%= t("courses.index.empty_description") %></p>
          </div>
        <% end %>

        <div class="mt-8">
          <%= render "shared/molecules/pagination",
            displayed_count: @courses.size,
            total_count: @total_count,
            per_page: @per_page,
            current_page: @current_page,
            total_pages: @total_pages,
            resource_name: t("pagination.resources.courses"),
            previous_path: (@current_page > 1 ? tenant_courses_path(tenant_slug: current_tenant.slug, page: @current_page - 1, filters: @filters) : nil),
            next_path: (@current_page < @total_pages ? tenant_courses_path(tenant_slug: current_tenant.slug, page: @current_page + 1, filters: @filters) : nil) %>
        </div>
      </section>
    </div>
  </div>
<% end %>
