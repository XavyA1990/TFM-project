<%= render "shared/organisms/marketing_hero",
  eyebrow: t(".eyebrow"),
  title: t(".title"),
  description: t(".description"),
  supporting_text: t(".supporting_text"),
  panel_eyebrow: t(".panel_eyebrow"),
  panel_title: t(".panel_title"),
  panel_description: t(".panel_description"),
  stats_portals_label: t(".stats.tenants"),
  stats_access_label: t(".stats.access"),
  stats_access_value: t(".stats.access_value"),
  portals_count: @tenants.size %>

<%= render "shared/organisms/partners_grid",
  partners: @tenants,
  title: t(".tenants_title"),
  description: t(".tenants_description"),
  count_label: t(".tenants_count", count: @tenants.size),
  portal_label: t(".tenant_link_label"),
  visit_label: t(".visit_tenant"),
  empty_description_label: t(".tenant_description_fallback"),
  empty_title: t(".empty_title"),
  empty_description: t(".empty_description"),
  path_builder: ->(tenant) { tenant_root_path(tenant_slug: tenant.slug) } %>
