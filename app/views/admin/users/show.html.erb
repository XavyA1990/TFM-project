<% breadcrumbs(
  { label: t("admin.users.index.title"), path: admin_users_path },
  { label: @user.full_name }
) %>

<%= render "shared/molecules/page_header", title: t(".title"), description: t(".description") %>
<%= render "shared/molecules/detail_list", items: @user_details %>
<%= render "shared/organisms/membership_roles",
  memberships: @user_tenant_roles,
  title: t(".tenant_roles_title"),
  description: t(".tenant_roles_description"),
  empty_message: t(".no_roles_assigned"),
  no_roles_label: t(".no_roles_assigned"),
  subject_label: Tenant.model_name.human,
  subject_name: ->(membership) { membership.tenant.name },
  subject_path: ->(membership) { admin_tenant_path(membership.tenant) } %>
<%= render "tenant_role_manager",
  user: @user,
  tenant_role_panels: @tenant_role_panels,
  available_roles: @available_roles %>
