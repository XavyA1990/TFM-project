<section class="mt-10">
  <div class="flex items-end justify-between gap-4 border-b border-gray-200 pb-4 dark:border-white/10">
    <div>
      <h2 class="text-lg font-semibold tracking-tight text-gray-900 dark:text-gray-100"><%= t("admin.users.show.tenant_role_manager_title") %></h2>
      <p class="mt-1 text-sm text-gray-600 dark:text-gray-400"><%= t("admin.users.show.tenant_role_manager_description") %></p>
    </div>
  </div>

  <div class="mt-6 grid gap-4">
    <% tenant_role_panels.each do |panel| %>
      <% tenant = panel[:tenant] %>
      <% membership = panel[:membership] %>
      <% assigned_roles = membership&.roles || [] %>
      <article class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-white/5">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
          <div class="min-w-0">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400"><%= Tenant.model_name.human %></p>
            <h3 class="mt-1 text-base font-semibold text-gray-900 dark:text-gray-100">
              <%= render "shared/atoms/text_link",
                text: tenant.name,
                path: admin_tenant_path(tenant),
                class_name: "text-base font-semibold" %>
            </h3>

            <div class="mt-4 flex flex-wrap gap-2">
              <% if assigned_roles.any? %>
                <% assigned_roles.each do |role| %>
                  <span class="inline-flex items-center rounded-full bg-emerald-100 px-3 py-1 text-sm font-semibold text-emerald-800 ring-1 ring-inset ring-emerald-200 dark:bg-emerald-500/15 dark:text-emerald-300 dark:ring-emerald-400/30">
                    <%= role.name %>
                  </span>
                <% end %>
              <% else %>
                <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-600 ring-1 ring-inset ring-gray-200 dark:bg-white/10 dark:text-gray-300 dark:ring-white/10">
                  <%= t("admin.users.show.no_roles_assigned") %>
                </span>
              <% end %>
            </div>
          </div>

          <%= form_with url: admin_user_role_assignments_path(user), method: :post,
            class: "w-full max-w-md",
            data: {
              controller: "role-assignment-toggle",
              "role-assignment-toggle-assigned-role-ids-value": assigned_roles.map(&:id).to_json,
              "role-assignment-toggle-add-label-value": t("admin.users.show.add_role"),
              "role-assignment-toggle-remove-label-value": t("admin.users.show.remove_role"),
            } do |form| %>
            <%= hidden_field_tag :tenant_id, tenant.id %>

            <div class="space-y-3">
              <div>
                <%= form.label :role_id, t("admin.users.show.role_select_label"), class: "block text-sm/6 font-medium text-gray-900 dark:text-white" %>
                <%= form.select :role_id,
                  options_for_select(available_roles.map { |role| [role.name, role.id] }, available_roles.first&.id),
                  {},
                  class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500",
                  data: {
                    "role-assignment-toggle-target": "select",
                    action: "change->role-assignment-toggle#update"
                  } %>
              </div>

              <button
                type="submit"
                class="w-full rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:cursor-pointer hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500"
                data-role-assignment-toggle-target="button"
                data-default-class="w-full rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:cursor-pointer hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500"
                data-danger-class="w-full rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:cursor-pointer hover:bg-red-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600 dark:bg-red-500 dark:hover:bg-red-400 dark:focus-visible:outline-red-500">
                <%= t("admin.users.show.add_role") %>
              </button>
            </div>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
</section>
