<%
  tenant_path_builder = local_assigns.fetch(:tenant_path_builder, ->(tenant) { admin_tenant_path(tenant) })
  role_assignment_path_builder = local_assigns.fetch(:role_assignment_path_builder, ->(user, _tenant) { admin_user_role_assignments_path(user) })
  tenant_token_enabled = local_assigns.fetch(:tenant_token_enabled, true)
  role_manager_title = local_assigns.fetch(:title, t("admin.users.show.tenant_role_manager_title"))
  role_manager_description = local_assigns.fetch(:description, t("admin.users.show.tenant_role_manager_description"))
  role_select_label = local_assigns.fetch(:role_select_label, t("admin.users.show.role_select_label"))
  add_role_label = local_assigns.fetch(:add_role_label, t("admin.users.show.add_role"))
  remove_role_label = local_assigns.fetch(:remove_role_label, t("admin.users.show.remove_role"))
  no_roles_assigned_label = local_assigns.fetch(:no_roles_assigned_label, t("admin.users.show.no_roles_assigned"))
  empty_title = local_assigns.fetch(:empty_title, t("admin.users.show.tenant_role_manager_empty_title"))
  empty_description = local_assigns.fetch(:empty_description, t("admin.users.show.tenant_role_manager_empty_description"))
%>

<% if can?(:assign, Role) %>
  <section class="mt-10">
    <%= render "shared/molecules/page_header",
      title: role_manager_title,
      description: role_manager_description,
      inner_class: "flex items-end justify-between gap-4 border-b border-gray-200 pb-4 dark:border-white/10",
      title_tag: :h2,
      title_class: "text-lg font-semibold tracking-tight text-gray-900 dark:text-gray-100",
      description_class: "mt-1 text-sm text-gray-600 dark:text-gray-400" %>

    <% if tenant_role_panels.any? %>
      <div class="mt-6 grid gap-4">
        <% tenant_role_panels.each do |panel| %>
          <% tenant = panel[:tenant] %>
          <% membership = panel[:membership] %>
          <% assigned_roles = membership&.roles || [] %>
          <% tenant_token = tenant.signed_id(purpose: :role_assignment) %>
          <% assigned_role_tokens = assigned_roles.map { |role| role.signed_id(purpose: :role_assignment) } %>
          <% available_role_options = available_roles.map { |role| [role.name, role.signed_id(purpose: :role_assignment)] } %>
          <article class="app-surface app-surface--admin-card p-5">
            <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400"><%= Tenant.model_name.human %></p>
                <h3 class="mt-1 text-base font-semibold text-gray-900 dark:text-gray-100">
                  <%= render "shared/atoms/text_link",
                    text: tenant.name,
                    path: tenant_path_builder.call(tenant),
                    class_name: "text-base font-semibold" %>
                </h3>

                <div class="mt-4 flex flex-wrap gap-2">
                  <% if assigned_roles.any? %>
                    <% assigned_roles.each do |role| %>
                      <%= render "shared/atoms/badge", text: role.name %>
                    <% end %>
                  <% else %>
                    <%= render "shared/atoms/badge", text: no_roles_assigned_label, variant: :neutral %>
                  <% end %>
                </div>
              </div>

              <%= form_with url: role_assignment_path_builder.call(user, tenant), method: :post,
                class: "w-full max-w-md",
                data: {
                  controller: "role-assignment-toggle",
                  "role-assignment-toggle-assigned-role-tokens-value": assigned_role_tokens.to_json,
                  "role-assignment-toggle-add-label-value": add_role_label,
                  "role-assignment-toggle-remove-label-value": remove_role_label,
                } do |form| %>
                <% if tenant_token_enabled %>
                  <%= hidden_field_tag :tenant_token, tenant_token %>
                <% end %>

                <div class="space-y-3">
                  <div>
                    <%= render "shared/molecules/select_field",
                      form: form,
                      field: :role_token,
                      label: role_select_label,
                      choices: options_for_select(available_role_options, available_role_options.first&.last),
                      input_html: {
                        data: {
                          "role-assignment-toggle-target": "select",
                          action: "change->role-assignment-toggle#update"
                        }
                      } %>
                  </div>

                <button
                  type="submit"
                  class="app-button app-button--primary w-full"
                  data-role-assignment-toggle-target="button"
                  data-default-class="app-button app-button--primary w-full"
                  data-danger-class="app-button app-button--danger w-full">
                  <%= add_role_label %>
                </button>
                </div>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/molecules/empty_state",
        title: empty_title,
        description: empty_description,
        class_name: "mt-6" %>
    <% end %>
  </section>
<% end %>
