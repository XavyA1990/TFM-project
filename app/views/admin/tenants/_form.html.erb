<%
  details_title = local_assigns.fetch(:details_title, t("admin.tenants.show.title"))
  details_description = local_assigns.fetch(:details_description, t("admin.tenants.show.description"))
  back_path = local_assigns.fetch(:back_path, admin_tenants_path)
%>

<%= form_with model: tenant, url: url, class: "mt-10" do |form| %>
  <%= render "shared/molecules/error_summary", resource: tenant %>

  <div class="space-y-12">
    <%= render layout: "shared/molecules/form_section",
      locals: {
        title: Tenant.human_attribute_name(:name),
        description: description
      } do %>
      <div class="sm:col-span-4">
        <%= render "shared/molecules/form_field", form: form, field: :name %>
      </div>

      <div class="col-span-full">
        <%= render "shared/molecules/form_field", form: form, field: :description, type: :text_area, input_html: { rows: 3 } %>
      </div>
    <% end %>

    <%= render layout: "shared/molecules/form_section",
      locals: {
        title: details_title,
        description: details_description
      } do %>
      <div class="col-span-full">
        <%= render "shared/molecules/form_field", form: form, field: :header_text %>
      </div>

      <div class="col-span-full">
        <%= render "shared/molecules/form_field", form: form, field: :subheader_text %>
      </div>

      <div class="col-span-full">
        <%= render "shared/organisms/asset_uploader",
          form: form,
          field: :logo_asset,
          type: :image,
          label: Tenant.human_attribute_name(:logo_asset),
          description: t("shared.asset_uploader.image_only_hint"),
          accept: "image/png,image/jpeg,image/webp",
          current_asset: tenant.logo_asset,
          current_url: tenant.logo_url %>
      </div>
    <% end %>
  </div>

  <%= render "shared/molecules/form_actions", back_path: back_path, submit_label: submit_label %>
<% end %>
