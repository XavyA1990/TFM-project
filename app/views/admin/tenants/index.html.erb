<%
  header_actions =
    if can?(:create, Tenant)
      capture do
        render "shared/atoms/button_link", text: t("admin.tenants.new.label"), path: new_admin_tenant_path
      end
    end
%>

<%= render "shared/molecules/page_header",
  title: t("admin.tenants.index.title"),
  description: t("admin.tenants.index.description"),
  wrapper_class: "mx-auto max-w-7xl px-4 sm:px-6 lg:px-8",
  inner_class: "sm:flex sm:items-center",
  content_class: "sm:flex-auto",
  actions_wrapper_class: "mt-4 sm:mt-0 sm:ml-16 sm:flex-none",
  title_tag: :h1,
  title_class: "text-base font-semibold text-gray-900 dark:text-white",
  description_class: "mt-2 text-sm text-gray-700 dark:text-gray-300",
  actions: header_actions %>

<%= render "shared/organisms/tenant_table",
  headers: @tenant_table_headers,
  columns: @tenant_table_columns,
  tenants: @tenants,
  empty_title: t(".empty_title"),
  empty_description: t(".empty_description") %>

<%= render "shared/molecules/pagination",
  displayed_count: @tenants.size,
  total_count: @total_count,
  per_page: @per_page,
  current_page: @current_page,
  total_pages: @total_pages,
  resource_name: t("pagination.resources.tenants"),
  previous_path: (@current_page > 1 ? admin_tenants_path(page: @current_page - 1) : nil),
  next_path: (@current_page < @total_pages ? admin_tenants_path(page: @current_page + 1) : nil) %>
