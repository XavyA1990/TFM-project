<%= render layout: "shared/molecules/auth_shell", locals: { title: t("devise.sessions.new.sign_in") } do %>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/form_field", f: f, field: :email, type: :email_field, label: t('email'), input_html: { autofocus: true, autocomplete: "email" } %>

    <%= render "devise/shared/form_field", f: f, field: :password, type: :password_field, label: t('password'), input_html: { autocomplete: "current-password" } %>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-3">
        <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600 dark:border-white/10 dark:bg-white/5 dark:focus:ring-indigo-500" %>
        <%= f.label :remember_me, t('remember_me'), class: "text-sm/6 text-gray-900 dark:text-white" %>
      </div>
    <% end %>

    <div class="actions">
      <%= render "shared/atoms/button", text: t('devise.sessions.new.sign_in'), type: :submit, class_name: "flex w-full justify-center py-1.5 text-sm/6 mb-5" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
