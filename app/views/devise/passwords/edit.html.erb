<%= render layout: "shared/molecules/auth_shell", locals: { title: t("devise_views.passwords.edit.title") } do %>
  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>

    <%= render "devise/shared/form_field", f: f, field: :password, type: :password_field, label: t('devise_views.passwords.edit.new_password'), description: (@minimum_password_length ? t('characters_minimum', count: @minimum_password_length) : nil), input_html: { autofocus: true, autocomplete: "new-password" } %>

    <%= render "devise/shared/form_field", f: f, field: :password_confirmation, type: :password_field, label: t('devise_views.passwords.edit.confirm_new_password'), input_html: { autocomplete: "new-password" } %>

    <div class="actions">
      <%= render "shared/atoms/button", text: t('devise_views.passwords.edit.submit'), type: :submit, class_name: "flex w-full justify-center py-1.5 text-sm/6 mb-5" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
