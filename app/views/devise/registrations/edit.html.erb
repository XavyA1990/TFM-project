<div class="flex min-h-full flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="text-2xl font-bold mb-4"><%= t('devise_views.registrations.edit.title') %></h2>
  </div>

  <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white px-6 py-12 shadow-sm sm:rounded-lg sm:px-12 dark:bg-gray-800/50 dark:shadow-none dark:outline dark:-outline-offset-1 dark:outline-white/10">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, t('email'), class: "block text-sm/6 font-medium text-gray-900 dark:text-white" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div class="rounded-md bg-amber-50 px-4 py-3 text-sm text-amber-800 dark:bg-amber-500/10 dark:text-amber-200">
            <%= t('devise_views.registrations.edit.pending_reconfirmation', email: resource.unconfirmed_email) %>
          </div>
        <% end %>

        <div>
          <div class="flex items-center justify-between gap-3">
            <%= f.label :password, t('password'), class: "block text-sm/6 font-medium text-gray-900 dark:text-white" %>
            <p class="text-sm/6 text-gray-500 dark:text-gray-400"><%= t('devise_views.registrations.edit.password_hint') %></p>
          </div>
          <% if @minimum_password_length %>
            <p><em class="text-sm/6 text-gray-500 dark:text-gray-400"><%= t('characters_minimum', count: @minimum_password_length) %></em></p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" %>
        </div>

        <div>
          <%= f.label :password_confirmation, t('password_confirmation'), class: "block text-sm/6 font-medium text-gray-900 dark:text-white" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" %>
        </div>

        <div>
          <div class="flex items-center justify-between gap-3">
            <%= f.label :current_password, t('current_password'), class: "block text-sm/6 font-medium text-gray-900 dark:text-white" %>
            <p class="text-sm/6 text-gray-500 dark:text-gray-400"><%= t('devise_views.registrations.edit.current_password_hint') %></p>
          </div>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" %>
        </div>

        <div class="actions">
          <%= f.submit t('update'), class: "flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm/6 font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:shadow-none dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500" %>
        </div>
      <% end %>

      <div class="mt-8 border-t border-gray-200 pt-6 dark:border-white/10">
        <h3 class="text-base font-semibold text-gray-900 dark:text-white"><%= t('devise_views.registrations.edit.cancel_account_title') %></h3>
        <p class="mt-2 text-sm/6 text-gray-500 dark:text-gray-400"><%= t('devise_views.registrations.edit.cancel_account_hint') %></p>
        <div class="mt-4">
          <%= button_to t('devise_views.registrations.edit.cancel_account_button'), registration_path(resource_name), data: { confirm: t('devise_views.registrations.edit.cancel_account_confirm'), turbo_confirm: t('devise_views.registrations.edit.cancel_account_confirm') }, method: :delete, form: { class: "w-full" }, class: "flex w-full justify-center rounded-md bg-red-600 px-3 py-1.5 text-sm/6 font-semibold text-white shadow-xs hover:bg-red-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600 dark:bg-red-500 dark:shadow-none dark:hover:bg-red-400 dark:focus-visible:outline-red-500" %>
        </div>
      </div>

      <div class="mt-6">
        <%= link_to t('back'), :back, class: "text-sm font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300" %>
      </div>
    </div>
  </div>
</div>
