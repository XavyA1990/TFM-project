<%= render layout: "shared/molecules/auth_shell", locals: { title: t("devise.registrations.new.sign_up") } do %>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= render "devise/shared/form_field", f: f, field: :email, type: :email_field, label: t('email'), input_html: { autofocus: true, autocomplete: "email", required: true } %>

    <%= render "devise/shared/form_field", f: f, field: :username, type: :text_field, label: t('username'), input_html: { autofocus: true, autocomplete: "username", required: true } %>

    <%= render "devise/shared/form_field", f: f, field: :first_name, type: :text_field, label: t('first_name'), input_html: { autofocus: true, autocomplete: "first_name", required: true } %>

    <%= render "devise/shared/form_field", f: f, field: :last_name, type: :text_field, label: t('last_name'), input_html: { autofocus: true, autocomplete: "last_name", required: true } %>

    <%= render "devise/shared/form_field", f: f, field: :password, type: :password_field, label: t('password'), description: (@minimum_password_length ? t('characters_minimum', count: @minimum_password_length) : nil), input_html: { autocomplete: "new-password", required: true } %>

    <%= render "devise/shared/form_field", f: f, field: :password_confirmation, type: :password_field, label: t('password_confirmation'), input_html: { autocomplete: "new-password", required: true } %>

    <div class="actions">
      <%= render "shared/atoms/button", text: t('devise.registrations.new.sign_up'), type: :submit, class_name: "flex w-full justify-center py-1.5 text-sm/6 mb-5" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
