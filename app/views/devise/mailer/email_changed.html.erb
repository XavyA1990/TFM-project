<p><%= t('devise_views.mailer.email_changed.greeting', email: @email) %></p>

<% if @resource.try(:unconfirmed_email?) %>
  <p><%= t('devise_views.mailer.email_changed.unconfirmed_message', email: @resource.unconfirmed_email) %></p>
<% else %>
  <p><%= t('devise_views.mailer.email_changed.confirmed_message', email: @resource.email) %></p>
<% end %>
