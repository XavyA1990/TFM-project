<%
  header_actions = capture do
    action_buttons = []

    if can?(:create, @course)
      action_buttons << render(
        "shared/atoms/button_link",
        text: t("admin_tenants.course_modules.new.label"),
        path: new_admin_tenants_course_course_module_path(tenant_slug: current_tenant.slug, course_id: @course.slug)
      )
    end

    if can?(:update, @course)
      action_buttons << render(
        "shared/atoms/button_link",
        text: t("admin_tenants.courses.edit.title"),
        path: edit_admin_tenants_course_path(tenant_slug: current_tenant.slug, id: @course.slug),
        variant: :secondary
      )
    end

    if can?(:destroy, @course)
      action_buttons << render(
        "shared/atoms/text_link",
        text: t("actions.delete"),
        path: admin_tenants_course_path(tenant_slug: current_tenant.slug, id: @course.slug),
        data: {
          turbo_method: :delete,
          turbo_confirm: t("actions.confirm_deletion", name: @course.title)
        },
        class_name: "text-sm font-semibold text-red-600 hover:text-red-500 dark:text-red-400 dark:hover:text-red-300"
      )
    end

    concat(
      content_tag(:div, class: "flex flex-wrap items-center gap-3") do
        safe_join(action_buttons)
      end
    )
  end
%>

<% breadcrumbs(
  { label: t("admin_tenants.tenants.show.title"), path: admin_tenants_tenant_path(tenant_slug: current_tenant.slug) },
  { label: t("admin_tenants.courses.index.title"), path: admin_tenants_courses_path(tenant_slug: current_tenant.slug) },
  { label: @course.title }
) %>

<%= render "shared/organisms/resource_show",
  title: t(".title"),
  description: t(".description"),
  details: @course_details,
  page_header_options: {
    wrapper_class: "mx-auto max-w-7xl px-4 sm:px-6 lg:px-8",
    inner_class: "sm:flex sm:items-center",
    content_class: "sm:flex-auto",
    actions_wrapper_class: "mt-4 sm:mt-0 sm:ml-16 sm:flex-none",
    title_tag: :h1,
    title_class: "text-base font-semibold text-gray-900 dark:text-white",
    description_class: "mt-2 text-sm text-gray-700 dark:text-gray-300",
    actions: header_actions
  },
  extra_partial: "admin_tenants/courses/course_modules",
  extra_locals: {
    course: @course,
    course_modules: @course_modules
  } %>
