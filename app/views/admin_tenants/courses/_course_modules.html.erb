<section class="mt-10">
  <%= render "shared/molecules/page_header",
    title: t("admin_tenants.courses.show.modules_title"),
    description: t("admin_tenants.courses.show.modules_description"),
    inner_class: "flex items-end justify-between gap-4 border-b border-gray-200 pb-4 dark:border-white/10",
    title_tag: :h2,
    title_class: "text-lg font-semibold tracking-tight text-gray-900 dark:text-gray-100",
    description_class: "mt-1 text-sm text-gray-600 dark:text-gray-400" %>

  <% if course_modules.any? %>
    <div class="mt-6 grid gap-6">
      <% course_modules.each do |course_module| %>
        <article class="app-surface app-surface--admin-card p-5" data-controller="disclosure">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <button
              type="button"
              data-action="click->disclosure#toggle"
              data-disclosure-target="button"
              aria-expanded="false"
              class="flex min-w-0 flex-1 items-start justify-between gap-4 text-left hover:cursor-pointer"
            >
              <div class="min-w-0 flex-1">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400">
                  <%= t("admin_tenants.courses.show.module_position", position: course_module[:position]) %>
                </p>
                <h3 class="mt-1 text-base font-semibold text-gray-900 dark:text-gray-100"><%= course_module[:title] %></h3>
              </div>

              <div class="ml-3 shrink-0">
                <%= render "shared/atoms/icon",
                  name: "chevron-down",
                  class_name: "size-5 text-gray-400 dark:text-gray-500",
                  data: { disclosure_target: "openIcon" } %>

                <%= render "shared/atoms/icon",
                  name: "chevron-up",
                  class_name: "hidden size-5 text-gray-400 dark:text-gray-500",
                  data: { disclosure_target: "closeIcon" } %>
              </div>
            </button>

            <div class="flex shrink-0 flex-wrap items-center gap-3 sm:pl-4">
              <%= render "shared/atoms/badge", text: course_module[:status] %>

              <% if can?(:update, course) %>
                <%= render "shared/atoms/text_link",
                  text: t("actions.edit"),
                  path: edit_admin_tenants_course_course_module_path(
                    tenant_slug: current_tenant.slug,
                    course_id: course.slug,
                    id: course_module[:slug]
                  ),
                  class_name: "text-sm font-semibold" %>
              <% end %>

              <% if can?(:destroy, course) %>
                <%= render "shared/atoms/text_link",
                  text: t("actions.delete"),
                  path: admin_tenants_course_course_module_path(
                    tenant_slug: current_tenant.slug,
                    course_id: course.slug,
                    id: course_module[:slug]
                  ),
                  base_class: "app-link app-link--danger",
                  class_name: "text-sm",
                  data: {
                    turbo_method: :delete,
                    turbo_confirm: t("actions.confirm_deletion", name: course_module[:title])
                  } %>
              <% end %>
            </div>
          </div>

          <div data-disclosure-target="panel" class="hidden pt-4">
            <%= render "shared/molecules/detail_list", items: [
              [CourseModule.human_attribute_name(:description), course_module[:description]],
              [CourseModule.human_attribute_name(:module_cover_image_asset), course_module[:module_cover_image]],
              [CourseModule.human_attribute_name(:created_at), course_module[:created_at]],
              [CourseModule.human_attribute_name(:updated_at), course_module[:updated_at]]
            ] %>

            <section class="mt-8">
              <%
                lesson_actions =
                  if can?(:create, course)
                    capture do
                      render "shared/atoms/button_link",
                        text: t("admin_tenants.lessons.new.label"),
                        path: new_admin_tenants_course_course_module_lesson_path(
                          tenant_slug: current_tenant.slug,
                          course_id: course.slug,
                          course_module_id: course_module[:slug]
                        )
                    end
                  end
              %>

              <%= render "shared/molecules/page_header",
                title: t("admin_tenants.courses.show.lessons_title"),
                description: t("admin_tenants.courses.show.lessons_description"),
                inner_class: "flex items-end justify-between gap-4 border-b border-gray-200 pb-4 dark:border-white/10",
                actions_wrapper_class: "mt-4 sm:mt-0 sm:ml-16 sm:flex-none",
                title_tag: :h3,
                title_class: "text-base font-semibold text-gray-900 dark:text-gray-100",
                description_class: "mt-1 text-sm text-gray-600 dark:text-gray-400",
                actions: lesson_actions %>

              <% if course_module[:lessons].any? %>
                <div class="mt-4 grid gap-4">
                  <% course_module[:lessons].each do |lesson| %>
                    <article class="app-surface app-surface--admin-card-subtle p-4">
                      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                        <div>
                          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400">
                            <%= t("admin_tenants.courses.show.lesson_position", position: lesson[:position]) %>
                          </p>
                          <h4 class="mt-1 text-sm font-semibold text-gray-900 dark:text-gray-100"><%= lesson[:title] %></h4>
                        </div>

                        <div class="flex flex-wrap items-center gap-2">
                          <%= render "shared/atoms/badge", text: lesson[:lesson_type], variant: :info, size: :xs %>
                          <%= render "shared/atoms/badge", text: lesson[:status], size: :xs %>

                          <% if can?(:update, course) %>
                            <%= render "shared/atoms/text_link",
                              text: t("actions.edit"),
                              path: edit_admin_tenants_course_course_module_lesson_path(
                                tenant_slug: current_tenant.slug,
                                course_id: course.slug,
                                course_module_id: course_module[:slug],
                                id: lesson[:slug]
                              ),
                              class_name: "text-sm font-semibold" %>
                          <% end %>

                          <% if can?(:destroy, course) %>
                            <%= render "shared/atoms/text_link",
                              text: t("actions.delete"),
                              path: admin_tenants_course_course_module_lesson_path(
                                tenant_slug: current_tenant.slug,
                                course_id: course.slug,
                                course_module_id: course_module[:slug],
                                id: lesson[:slug]
                              ),
                              base_class: "app-link app-link--danger",
                              class_name: "text-sm",
                              data: {
                                turbo_method: :delete,
                                turbo_confirm: t("actions.confirm_deletion", name: lesson[:title])
                              } %>
                          <% end %>
                        </div>
                      </div>

                      <%= render "shared/molecules/detail_list", items: [
                        [Lesson.human_attribute_name(:description), lesson[:description]],
                        [Lesson.human_attribute_name(:body), lesson[:body]],
                        [Lesson.human_attribute_name(:lesson_content_asset), lesson[:content_reference]],
                        [Lesson.human_attribute_name(:created_at), lesson[:created_at]],
                        [Lesson.human_attribute_name(:updated_at), lesson[:updated_at]]
                      ] %>
                    </article>
                  <% end %>
                </div>
              <% else %>
                <%= render "shared/molecules/empty_state",
                  message: t("admin_tenants.courses.show.empty_lessons"),
                  class_name: "mt-4" %>
              <% end %>
            </section>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/molecules/empty_state",
      message: t("admin_tenants.courses.show.empty_modules"),
      class_name: "mt-6" %>
  <% end %>
</section>
