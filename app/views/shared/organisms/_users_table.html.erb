<div class="mt-8 flow-root overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <table class="w-full text-left">
      <thead class="bg-white dark:bg-gray-900">
        <% headers.each do |header| %>
          <th scope="col" class="hidden px-3 py-3.5 text-left text-sm font-semibold text-gray-900 sm:table-cell dark:text-white"><%= header %></th>
        <% end %>
        <th scope="col" class="py-3.5 pl-3">
          <span class="sr-only"><%= t("actions.actions") %></span>
        </th>
      </thead>
      <tbody>
        <% users.each do |user| %>
          <tr>
            <% columns.each do |column| %>
              <td class="hidden px-3 py-4 text-sm text-gray-500 sm:table-cell dark:text-gray-400"><%= user[column] %></td>
            <% end %>
            <td class="py-4 pl-3 text-right text-sm font-medium">
              <%= render "shared/atoms/text_link", text: t("actions.view"), path: admin_user_path(user[:slug]), class_name: "font-medium" %>
              <span class="sr-only">, <%= user[:full_name] %></span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
