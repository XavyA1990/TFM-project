<%
  user_path_builder = local_assigns.fetch(:user_path_builder, ->(user) { admin_user_path(user[:slug]) })
  user_actions_builder = lambda do |user|
    [{ text: t("actions.view"), path: user_path_builder.call(user) }]
  end
%>

<%= render "shared/organisms/resource_table",
  records: users,
  headers: headers,
  columns: columns,
  mobile_title_builder: ->(user) { user[:full_name] },
  mobile_subtitle_builder: ->(user) { user[:email] },
  record_name_builder: ->(user) { user[:full_name] },
  skip_mobile_columns: %i[full_name email],
  action_column_count: 1,
  actions_builder: user_actions_builder %>
