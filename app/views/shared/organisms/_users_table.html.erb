<%
  user_path_builder = local_assigns.fetch(:user_path_builder, ->(user) { admin_user_path(user[:slug]) })
%>

<div class="mt-8 flow-root">
  <div class="mx-auto max-w-7xl px-4 sm:hidden">
    <div class="space-y-4">
      <% users.each do |user| %>
        <article class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm dark:border-white/10 dark:bg-white/5">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-base font-semibold text-gray-900 dark:text-white"><%= user[:full_name] %></h2>
              <% if user[:email].present? %>
                <p class="mt-1 break-all text-sm text-gray-500 dark:text-gray-400"><%= user[:email] %></p>
              <% end %>
            </div>
          </div>

          <dl class="mt-4 space-y-3">
            <% headers.zip(columns).each do |header, column| %>
              <% next if column.to_sym == :full_name || column.to_sym == :email %>
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400"><%= header %></dt>
                <dd class="mt-1 text-sm text-gray-700 dark:text-gray-300"><%= user[column].presence || "-" %></dd>
              </div>
            <% end %>
          </dl>

          <div class="mt-5 border-t border-gray-200 pt-4 text-center dark:border-white/10">
            <%= render "shared/atoms/text_link", text: t("actions.view"), path: user_path_builder.call(user), class_name: "text-sm font-semibold" %>
          </div>
        </article>
      <% end %>
    </div>
  </div>

  <div class="hidden overflow-hidden sm:block">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <table class="w-full text-left">
        <thead class="bg-white dark:bg-gray-900">
          <tr>
            <% headers.each do |header| %>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white"><%= header %></th>
            <% end %>
            <th scope="col" class="py-3.5 pl-3">
              <span class="sr-only"><%= t("actions.actions") %></span>
            </th>
          </tr>
        </thead>
        <tbody>
          <% users.each do |user| %>
            <tr>
              <% columns.each do |column| %>
                <td class="px-3 py-4 text-sm text-gray-500 dark:text-gray-400"><%= user[column] %></td>
              <% end %>
              <td class="py-4 pl-3 text-right text-sm font-medium">
                <%= render "shared/atoms/text_link", text: t("actions.view"), path: user_path_builder.call(user), class_name: "font-medium" %>
                <span class="sr-only">, <%= user[:full_name] %></span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
