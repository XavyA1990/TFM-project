<section class="relative isolate overflow-hidden">
  <div class="app-background app-background--aurora-portal absolute inset-0 -z-10"></div>

  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1.25fr)_minmax(22rem,0.75fr)] lg:items-start">
      <div class="max-w-3xl">
        <p class="app-text app-text--brand text-sm font-semibold uppercase tracking-[0.24em]"><%= eyebrow %></p>
        <h1 class="app-text app-text--strong mt-4 text-4xl font-black tracking-tight sm:text-5xl lg:text-6xl">
          <%= title %>
        </h1>
        <p class="app-text app-text--body mt-6 max-w-2xl text-lg leading-8">
          <%= description %>
        </p>
        <p class="app-text app-text--muted mt-4 max-w-2xl text-sm leading-7">
          <%= supporting_text %>
        </p>
      </div>

      <div class="app-surface app-surface--card p-6">
        <p class="app-text app-text--brand-soft text-sm font-semibold uppercase tracking-[0.18em]"><%= panel_eyebrow %></p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="app-surface app-surface--card-strong p-4">
            <p class="app-text app-text--muted text-xs font-semibold uppercase tracking-[0.18em]"><%= stats_portals_label %></p>
            <p class="app-text app-text--strong mt-2 text-3xl font-black"><%= portals_count %></p>
          </div>
          <div class="app-surface app-surface--card-strong p-4">
            <p class="app-text app-text--muted text-xs font-semibold uppercase tracking-[0.18em]"><%= stats_access_label %></p>
            <p class="app-text app-text--strong mt-2 text-base font-semibold"><%= stats_access_value %></p>
          </div>
        </div>

        <div class="app-surface app-surface--card-strong mt-6 p-4">
          <p class="app-text app-text--strong text-sm font-semibold"><%= panel_title %></p>
          <p class="app-text app-text--body mt-2 text-sm leading-6"><%= panel_description %></p>
        </div>
      </div>
    </div>
  </div>
</section>
