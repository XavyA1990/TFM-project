<%
  courses = local_assigns.fetch(:courses, [])
  use_carousel = courses.size >= 3
%>

<section class="relative isolate overflow-hidden py-16 sm:py-20">
  <div class="app-background app-background--aurora-showcase absolute inset-0 -z-10"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <%= render "shared/molecules/page_header",
      title: t("tenants.show.courses.title"),
      description: t("tenants.show.courses.description"),
      wrapper_class: "px-0",
      title_tag: :h2,
      title_class: "app-text app-text--strong text-2xl font-black tracking-tight sm:text-3xl",
      description_class: "app-text app-text--body mt-3 max-w-2xl text-sm leading-6" %>

    <% if courses.any? %>
      <% if use_carousel %>
        <div data-controller="carousel" class="app-carousel mt-10">
          <div class="mb-5 flex items-center justify-end gap-3">
            <button
              type="button"
              data-action="click->carousel#previous"
              class="app-carousel__control"
              aria-label="<%= t('tenants.show.courses.previous') %>"
            >
              <span aria-hidden="true">&larr;</span>
            </button>
            <button
              type="button"
              data-action="click->carousel#next"
              class="app-carousel__control"
              aria-label="<%= t('tenants.show.courses.next') %>"
            >
              <span aria-hidden="true">&rarr;</span>
            </button>
          </div>

          <div
            data-carousel-target="viewport"
            class="-mx-4 flex snap-x snap-mandatory gap-6 overflow-x-auto px-4 pb-4 [scrollbar-width:none] sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8 [&::-webkit-scrollbar]:hidden"
          >
            <% courses.each do |course| %>
              <%= render "shared/organisms/tenant_course_card",
                course: course,
                carousel: true,
                path: tenant_course_path(tenant_slug: current_tenant.slug, id: course[:slug]),
                cta_text: t("tenants.show.courses.cta") %>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="mt-10 grid gap-6 md:grid-cols-2">
          <% courses.each do |course| %>
            <%= render "shared/organisms/tenant_course_card",
              course: course,
              path: tenant_course_path(tenant_slug: current_tenant.slug, id: course[:slug]),
              cta_text: t("tenants.show.courses.cta") %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <%= render "shared/molecules/empty_state",
        title: t("tenants.show.courses.empty_title"),
        description: t("tenants.show.courses.empty_description"),
        variant: :portal,
        class_name: "mt-10" %>
    <% end %>
  </div>
</section>
