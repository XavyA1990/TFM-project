<%
  value_builder = local_assigns.fetch(:value_builder, ->(record, column) { record[column] })
  mobile_title_builder = local_assigns.fetch(:mobile_title_builder)
  mobile_subtitle_builder = local_assigns[:mobile_subtitle_builder]
  record_name_builder = local_assigns.fetch(:record_name_builder, mobile_title_builder)
  actions_builder = local_assigns.fetch(:actions_builder, ->(_record) { [] })
  skip_mobile_columns = Array(local_assigns[:skip_mobile_columns]).map(&:to_sym)
  action_column_count = local_assigns.fetch(:action_column_count, 1)
%>

<div class="mt-8 flow-root">
  <div class="mx-auto max-w-7xl px-4 sm:hidden">
    <div class="space-y-4">
      <% records.each do |record| %>
        <% actions = actions_builder.call(record) %>
        <article class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm dark:border-white/10 dark:bg-white/5">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-base font-semibold text-gray-900 dark:text-white"><%= mobile_title_builder.call(record) %></h2>
              <% if mobile_subtitle_builder.present? && mobile_subtitle_builder.call(record).present? %>
                <p class="mt-1 break-all text-sm text-gray-500 dark:text-gray-400"><%= mobile_subtitle_builder.call(record) %></p>
              <% end %>
            </div>
          </div>

          <dl class="mt-4 space-y-3">
            <% headers.zip(columns).each do |header, column| %>
              <% next if skip_mobile_columns.include?(column.to_sym) %>
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400"><%= header %></dt>
                <dd class="mt-1 text-sm text-gray-700 dark:text-gray-300"><%= value_builder.call(record, column).presence || "-" %></dd>
              </div>
            <% end %>
          </dl>

          <% if actions.any? %>
            <div class="mt-5 flex flex-wrap gap-3 border-t border-gray-200 pt-4 dark:border-white/10">
              <% actions.each do |action| %>
                <div class="min-w-0 flex-1 text-center">
                  <%= render "shared/atoms/text_link",
                    text: action[:text],
                    path: action[:path],
                    class_name: action[:class_name] || "text-sm font-semibold",
                    data: action[:data] %>
                </div>
              <% end %>
            </div>
          <% end %>
        </article>
      <% end %>
    </div>
  </div>

  <div class="hidden overflow-hidden sm:block">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <table class="w-full text-left">
        <thead class="bg-white dark:bg-gray-900">
          <tr>
            <% headers.each do |header| %>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white"><%= header %></th>
            <% end %>
            <% action_column_count.times do %>
              <th scope="col" class="py-3.5 pl-3">
                <span class="sr-only"><%= t("actions.actions") %></span>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% records.each do |record| %>
            <% actions = actions_builder.call(record) %>
            <tr>
              <% columns.each do |column| %>
                <td class="px-3 py-4 text-sm text-gray-500 dark:text-gray-400"><%= value_builder.call(record, column) %></td>
              <% end %>
              <% actions.each do |action| %>
                <td class="py-4 pl-3 text-right text-sm font-medium">
                  <%= render "shared/atoms/text_link",
                    text: action[:text],
                    path: action[:path],
                    class_name: action[:class_name] || "font-medium",
                    data: action[:data] %>
                  <span class="sr-only">, <%= record_name_builder.call(record) %></span>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
