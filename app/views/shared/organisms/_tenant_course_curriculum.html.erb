<%
  course = local_assigns.fetch(:course)
%>

<section class="relative isolate overflow-hidden py-16 sm:py-20">
  <div class="app-background app-background--aurora-curriculum absolute inset-0 -z-10"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <%= render "shared/molecules/page_header",
      title: t("courses.show.curriculum.title"),
      description: t("courses.show.curriculum.description", count: course[:module_count]),
      wrapper_class: "px-0",
      title_tag: :h2,
      title_class: "app-text app-text--strong text-3xl font-black tracking-tight sm:text-4xl",
      description_class: "app-text app-text--body mt-3 max-w-2xl text-sm leading-6" %>

    <% if course[:modules].any? %>
      <div class="mt-10 grid items-start gap-4 lg:grid-cols-2">
        <% course[:modules].each do |course_module| %>
          <article class="app-surface app-surface--card self-start p-5" data-controller="disclosure">
            <button
              type="button"
              data-action="click->disclosure#toggle"
              data-disclosure-target="button"
              aria-expanded="false"
              class="flex w-full items-start justify-between gap-4 text-left hover:cursor-pointer"
            >
              <div class="min-w-0 flex-1">
                <p class="app-text app-text--accent text-xs font-semibold uppercase tracking-[0.2em]">
                  <%= t("courses.show.curriculum.module_position", position: course_module[:position]) %>
                </p>
                <h3 class="app-text app-text--strong mt-3 text-lg font-bold"><%= course_module[:title] %></h3>
                <% if course_module[:description].present? %>
                  <p class="app-text app-text--body mt-2 text-sm leading-6"><%= course_module[:description] %></p>
                <% end %>
              </div>

              <div class="app-surface app-surface--card-strong shrink-0 px-3 py-2 text-right">
                <p class="app-text app-text--muted text-xs font-semibold uppercase tracking-[0.16em]">
                  <%= t("courses.show.curriculum.lessons_label") %>
                </p>
                <p class="app-text app-text--strong mt-1 text-lg font-black"><%= course_module[:lesson_count] %></p>
              </div>

              <div class="mt-1 shrink-0">
                <svg
                  data-disclosure-target="openIcon"
                  class="app-text app-text--muted size-5"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                </svg>

                <svg
                  data-disclosure-target="closeIcon"
                  class="app-text app-text--muted hidden size-5"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path fill-rule="evenodd" d="M14.77 12.79a.75.75 0 01-1.06-.02L10 8.83l-3.71 3.94a.75.75 0 11-1.08-1.04l4.25-4.5a.75.75 0 011.08 0l4.25 4.5a.75.75 0 01-.02 1.06z" clip-rule="evenodd" />
                </svg>
              </div>
            </button>

            <div data-disclosure-target="panel" class="hidden pt-5">
              <% if course_module[:lessons].any? %>
                <ol class="space-y-3">
                  <% course_module[:lessons].each do |lesson| %>
                    <li class="app-surface app-surface--card-strong px-4 py-3">
                      <p class="app-text app-text--muted text-xs font-semibold uppercase tracking-[0.16em]">
                        <%= t("courses.show.curriculum.lesson_position", position: lesson[:position]) %>
                      </p>
                      <p class="app-text app-text--strong mt-2 text-sm font-semibold"><%= lesson[:title] %></p>
                    </li>
                  <% end %>
                </ol>
              <% else %>
                <%= render "shared/molecules/empty_state",
                  message: t("courses.show.curriculum.empty_lessons"),
                  variant: :portal_strong %>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/molecules/empty_state",
        title: t("courses.show.curriculum.empty_title"),
        description: t("courses.show.curriculum.empty_description"),
        variant: :portal,
        class_name: "mt-10" %>
    <% end %>
  </div>
</section>
