<%
  course = local_assigns.fetch(:course)
%>

<section class="relative isolate overflow-hidden py-16 sm:py-20">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_right,_rgba(99,102,241,0.18),_transparent_30%),radial-gradient(circle_at_bottom_left,_rgba(14,165,233,0.14),_transparent_24%)]"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <%= render "shared/molecules/page_header",
      title: t("courses.show.curriculum.title"),
      description: t("courses.show.curriculum.description", count: course[:module_count]),
      wrapper_class: "px-0",
      title_tag: :h2,
      title_class: "text-3xl font-black tracking-tight text-white sm:text-4xl",
      description_class: "mt-3 max-w-2xl text-sm leading-6 text-gray-300" %>

    <% if course[:modules].any? %>
      <div class="mt-10 grid items-start gap-4 lg:grid-cols-2">
        <% course[:modules].each do |course_module| %>
          <article class="self-start rounded-3xl border border-white/10 bg-white/5 p-5 shadow-2xl shadow-black/20 backdrop-blur" data-controller="disclosure">
            <button
              type="button"
              data-action="click->disclosure#toggle"
              data-disclosure-target="button"
              aria-expanded="false"
              class="flex w-full items-start justify-between gap-4 text-left hover:cursor-pointer"
            >
              <div class="min-w-0 flex-1">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sky-300">
                  <%= t("courses.show.curriculum.module_position", position: course_module[:position]) %>
                </p>
                <h3 class="mt-3 text-lg font-bold text-white"><%= course_module[:title] %></h3>
                <% if course_module[:description].present? %>
                  <p class="mt-2 text-sm leading-6 text-gray-300"><%= course_module[:description] %></p>
                <% end %>
              </div>

              <div class="shrink-0 rounded-2xl border border-white/10 bg-gray-950/40 px-3 py-2 text-right">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-400">
                  <%= t("courses.show.curriculum.lessons_label") %>
                </p>
                <p class="mt-1 text-lg font-black text-white"><%= course_module[:lesson_count] %></p>
              </div>

              <div class="mt-1 shrink-0">
                <svg
                  data-disclosure-target="openIcon"
                  class="size-5 text-gray-400"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                </svg>

                <svg
                  data-disclosure-target="closeIcon"
                  class="hidden size-5 text-gray-400"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path fill-rule="evenodd" d="M14.77 12.79a.75.75 0 01-1.06-.02L10 8.83l-3.71 3.94a.75.75 0 11-1.08-1.04l4.25-4.5a.75.75 0 011.08 0l4.25 4.5a.75.75 0 01-.02 1.06z" clip-rule="evenodd" />
                </svg>
              </div>
            </button>

            <div data-disclosure-target="panel" class="hidden pt-5">
              <% if course_module[:lessons].any? %>
                <ol class="space-y-3">
                  <% course_module[:lessons].each do |lesson| %>
                    <li class="rounded-2xl border border-white/10 bg-gray-950/40 px-4 py-3">
                      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-400">
                        <%= t("courses.show.curriculum.lesson_position", position: lesson[:position]) %>
                      </p>
                      <p class="mt-2 text-sm font-semibold text-white"><%= lesson[:title] %></p>
                    </li>
                  <% end %>
                </ol>
              <% else %>
                <div class="rounded-2xl border border-dashed border-white/10 bg-gray-950/40 p-4 text-sm text-gray-300">
                  <%= t("courses.show.curriculum.empty_lessons") %>
                </div>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="mt-10 rounded-3xl border border-dashed border-white/10 bg-white/5 p-8 text-center">
        <p class="text-base font-semibold text-white"><%= t("courses.show.curriculum.empty_title") %></p>
        <p class="mt-2 text-sm leading-6 text-gray-300"><%= t("courses.show.curriculum.empty_description") %></p>
      </div>
    <% end %>
  </div>
</section>
