<%
  tenant = local_assigns.fetch(:tenant)
  eyebrow = local_assigns.fetch(:eyebrow, t("tenants.show.eyebrow"))
  title = tenant.header_text.presence || t("tenants.show.fallback_title", tenant: tenant.name)
  description = tenant.subheader_text.presence || t("tenants.show.fallback_description", tenant: tenant.name)
  portal_label = local_assigns.fetch(:portal_label, t("tenants.show.portal_label"))
  about_text = tenant.description.presence || t("tenants.show.about_panel_description", tenant: tenant.name)
%>

<section class="relative isolate overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,_rgba(99,102,241,0.22),_transparent_32%),radial-gradient(circle_at_bottom_right,_rgba(14,165,233,0.16),_transparent_28%)]"></div>

  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_minmax(20rem,0.8fr)] lg:items-start">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-indigo-400"><%= eyebrow %></p>
        <h1 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl lg:text-6xl">
          <%= title %>
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-gray-300">
          <%= description %>
        </p>
      </div>

      <div class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl shadow-black/20 backdrop-blur">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-300"><%= portal_label %></p>
            <p class="mt-4 truncate text-2xl font-black text-white"><%= tenant.name %></p>
            <p class="mt-2 text-sm text-gray-400"><%= tenant.slug %></p>
          </div>
          <div class="flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-2xl border border-white/10 bg-gray-950/40 text-lg font-bold uppercase text-indigo-300">
            <% if tenant.logo_source.present? %>
              <%= image_tag tenant.logo_source, alt: tenant.name, class: "size-full object-contain p-2" %>
            <% else %>
              <%= tenant.name.first %>
            <% end %>
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-white/10 bg-gray-950/40 p-4">
          <p class="text-sm font-semibold text-white"><%= t("tenants.show.about_panel_title") %></p>
          <p class="mt-2 text-sm leading-6 text-gray-300"><%= about_text %></p>
        </div>
      </div>
    </div>
  </div>
</section>
