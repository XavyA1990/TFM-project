<%
  tenant = local_assigns.fetch(:tenant)
  eyebrow = local_assigns.fetch(:eyebrow, t("tenants.show.eyebrow"))
  title = tenant.header_text.presence || t("tenants.show.fallback_title", tenant: tenant.name)
  description = tenant.subheader_text.presence || t("tenants.show.fallback_description", tenant: tenant.name)
  portal_label = local_assigns.fetch(:portal_label, t("tenants.show.portal_label"))
  about_text = tenant.description.presence || t("tenants.show.about_panel_description", tenant: tenant.name)
%>

<section class="relative isolate overflow-hidden">
  <div class="app-background app-background--aurora-portal absolute inset-0 -z-10"></div>

  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_minmax(20rem,0.8fr)] lg:items-start">
      <div class="max-w-3xl">
        <p class="app-text app-text--brand text-sm font-semibold uppercase tracking-[0.24em]"><%= eyebrow %></p>
        <h1 class="app-text app-text--strong mt-4 text-4xl font-black tracking-tight sm:text-5xl lg:text-6xl">
          <%= title %>
        </h1>
        <p class="app-text app-text--body mt-6 max-w-2xl text-lg leading-8">
          <%= description %>
        </p>
      </div>

      <div class="app-surface app-surface--card p-6">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0">
            <p class="app-text app-text--brand-soft text-sm font-semibold uppercase tracking-[0.18em]"><%= portal_label %></p>
            <p class="app-text app-text--strong mt-4 truncate text-2xl font-black"><%= tenant.name %></p>
            <p class="app-text app-text--muted mt-2 text-sm"><%= tenant.slug %></p>
          </div>
          <div class="app-surface app-surface--card-strong app-text app-text--brand-soft flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden text-lg font-bold uppercase">
            <% if tenant.logo_source.present? %>
              <%= image_tag tenant.logo_source, alt: tenant.name, class: "size-full object-contain p-2" %>
            <% else %>
              <%= tenant.name.first %>
            <% end %>
          </div>
        </div>

        <div class="app-surface app-surface--card-strong mt-6 p-4">
          <p class="app-text app-text--strong text-sm font-semibold"><%= t("tenants.show.about_panel_title") %></p>
          <p class="app-text app-text--body mt-2 text-sm leading-6"><%= about_text %></p>
        </div>
      </div>
    </div>
  </div>
</section>
