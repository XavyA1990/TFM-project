<%
  course_path_builder = local_assigns.fetch(:course_path_builder, ->(course) { admin_tenants_course_path(tenant_slug: current_tenant.slug, id: course[:slug]) })
  edit_course_path_builder = local_assigns.fetch(:edit_course_path_builder, ->(course) { edit_admin_tenants_course_path(tenant_slug: current_tenant.slug, id: course[:slug]) })
  delete_course_path_builder = local_assigns.fetch(:delete_course_path_builder, ->(course) { admin_tenants_course_path(tenant_slug: current_tenant.slug, id: course[:slug]) })

  course_actions_builder = lambda do |course|
    actions = []

    if can?(:read, Course)
      actions << {
        text: t("actions.view"),
        path: course_path_builder.call(course)
      }
    end

    if can?(:update, Course)
      actions << {
        text: t("actions.edit"),
        path: edit_course_path_builder.call(course)
      }
    end

    if can?(:destroy, Course)
      actions << {
        text: t("actions.delete"),
        path: delete_course_path_builder.call(course),
        data: {
          turbo_method: :delete,
          turbo_confirm: t("actions.confirm_deletion", name: course[:title])
        }
      }
    end

    actions
  end
%>

<%= render "shared/organisms/resource_table",
  records: courses,
  headers: headers,
  columns: columns,
  mobile_title_builder: ->(course) { course[:title] },
  mobile_subtitle_builder: ->(course) { course[:status] },
  record_name_builder: ->(course) { course[:title] },
  skip_mobile_columns: %i[title status],
  action_column_count: 3,
  actions_builder: course_actions_builder %>
