<section class="mt-10">
  <%= render "shared/molecules/page_header",
    title: title,
    description: description,
    inner_class: "flex items-end justify-between gap-4 border-b border-gray-200 pb-4 dark:border-white/10",
    title_tag: :h2,
    title_class: "text-lg font-semibold tracking-tight text-gray-900 dark:text-gray-100",
    description_class: "mt-1 text-sm text-gray-600 dark:text-gray-400" %>

  <% if memberships.any? %>
    <div class="mt-6 grid gap-4">
      <% memberships.each do |membership| %>
        <article class="app-surface app-surface--admin-card p-5">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400"><%= subject_label %></p>
              <h3 class="mt-1 text-base font-semibold text-gray-900 dark:text-gray-100">
                <%= render "shared/atoms/text_link",
                  text: subject_name.call(membership),
                  path: subject_path.call(membership),
                  class_name: "text-base font-semibold" %>
              </h3>
            </div>

            <div class="flex flex-wrap gap-2 sm:justify-end">
              <% if membership.roles.any? %>
                <% membership.roles.each do |role| %>
                  <%= render "shared/atoms/badge", text: role.name %>
                <% end %>
              <% else %>
                <%= render "shared/atoms/badge", text: no_roles_label, variant: :neutral %>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/molecules/empty_state",
      message: empty_message,
      class_name: "mt-6" %>
  <% end %>
</section>
