<%
  tenant_actions_builder = lambda do |tenant|
    actions = []

    if can?(:read, tenant)
      actions << { text: t("actions.view"), path: admin_tenant_path(tenant) }
    end

    if can?(:update, tenant)
      actions << { text: t("actions.edit"), path: edit_admin_tenant_path(tenant) }
    end

    if can?(:destroy, tenant)
      actions << {
        text: t("actions.delete"),
        path: admin_tenant_path(tenant),
        data: { turbo_method: :delete, turbo_confirm: t("actions.confirm_deletion", name: tenant[:name]) }
      }
    end

    actions
  end
%>

<%= render "shared/organisms/resource_table",
  records: tenants,
  headers: headers,
  columns: columns,
  mobile_title_builder: ->(tenant) { tenant[:name] },
  mobile_subtitle_builder: ->(tenant) { tenant[:slug] },
  record_name_builder: ->(tenant) { tenant[:name] },
  skip_mobile_columns: %i[name],
  action_column_count: 3,
  actions_builder: tenant_actions_builder %>
