<%
  variant = local_assigns.fetch(:variant, :primary).to_sym
  type = local_assigns.fetch(:type, :button)
  class_name = local_assigns[:class_name]

  base_class =
    case variant
    when :danger
      "rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-red-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600 dark:bg-red-500 dark:shadow-none dark:hover:bg-red-400 dark:focus-visible:outline-red-500 hover:cursor-pointer"
    else
      "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:shadow-none dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500 hover:cursor-pointer"
    end
%>

<button type="<%= type %>" class="<%= [base_class, class_name].compact.join(" ") %>"><%= text %></button>
