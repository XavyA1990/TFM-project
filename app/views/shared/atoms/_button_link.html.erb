<%
  variant = local_assigns.fetch(:variant, :primary).to_sym
  class_name = local_assigns[:class_name]
  data = local_assigns[:data]

  base_class =
    case variant
    when :secondary
      "app-button app-button--secondary"
    else
      "app-button app-button--primary block text-center"
    end
%>

<%= link_to text, path, class: [base_class, class_name].compact.join(" "), data: data %>
