<%
  label = local_assigns.fetch(:label)
  value = local_assigns.fetch(:value)
%>

<div class="app-surface app-surface--card-strong p-4">
  <p class="app-text app-text--accent text-xs font-semibold uppercase tracking-[0.2em]"><%= label %></p>
  <p class="app-text app-text--strong mt-2 text-2xl font-black tracking-tight"><%= value %></p>
</div>
