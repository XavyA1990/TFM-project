<% return if links.blank? %>

<li>
  <% if local_assigns[:title].present? %>
    <div class="text-xs/6 font-semibold text-gray-400"><%= title %></div>
  <% end %>

  <ul role="list" class="<%= local_assigns[:list_class] || '-mx-2 space-y-1' %>">
    <% links.each do |link| %>
      <% active = link[:active] %>
      <li>
        <%= link_to link[:path], class: [
          "group flex gap-x-3 rounded-md p-2 text-sm/6 font-semibold transition-colors",
          active ? "bg-gray-50 text-indigo-600 dark:bg-white/5 dark:text-white" : "text-gray-700 hover:bg-gray-50 hover:text-indigo-600 dark:text-gray-400 dark:hover:bg-white/5 dark:hover:text-white"
        ].join(" ") do %>
          <span class="flex size-6 shrink-0 items-center justify-center overflow-hidden rounded-lg border text-[0.625rem] font-medium <%= active ? 'border-indigo-600 bg-indigo-50 text-indigo-600 dark:border-white/20 dark:bg-white/10 dark:text-white' : 'border-gray-200 bg-white text-gray-400 group-hover:border-indigo-600 group-hover:text-indigo-600 dark:border-white/15 dark:bg-white/5 dark:group-hover:border-white/20 dark:group-hover:text-white' %>">
            <% if link[:icon_image].present? %>
              <%= image_tag link[:icon_image], alt: link[:label], class: "size-full object-cover" %>
            <% else %>
              <%= link[:label].to_s.first&.upcase %>
            <% end %>
          </span>
          <span class="truncate"><%= link[:label] %></span>
        <% end %>
      </li>
    <% end %>
  </ul>
</li>
