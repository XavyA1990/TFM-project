<div class="relative flex h-full grow flex-col gap-y-5 overflow-y-auto border-r border-gray-200 bg-white px-6 py-6 text-gray-900 shadow-sm dark:border-white/10 dark:bg-gray-900 dark:text-white dark:before:pointer-events-none dark:before:absolute dark:before:inset-0 dark:before:bg-black/10 lg:h-screen lg:pt-20 lg:shadow-none">
  <div class="relative flex h-16 shrink-0 items-center gap-x-3">
    <div class="flex size-10 items-center justify-center rounded-xl bg-indigo-600 text-sm font-bold text-white shadow-sm dark:bg-indigo-500">
      <%= sidebar[:title].to_s.first&.upcase || "D" %>
    </div>
    <div class="min-w-0">
      <%= render "shared/atoms/text_link",
        text: sidebar[:title],
        path: sidebar[:home_path],
        base_class: "text-gray-900 hover:text-indigo-600 dark:text-white dark:hover:text-indigo-300",
        class_name: "truncate text-sm font-semibold" %>
      <p class="text-xs text-gray-500 dark:text-gray-400"><%= t("app.name") %></p>
    </div>
  </div>

  <nav class="relative flex flex-1 flex-col">
    <ul role="list" class="flex flex-1 flex-col gap-y-7">
      <li>
        <ul role="list" class="-mx-2 space-y-1">
          <% sidebar[:primary_links].each do |link| %>
            <% active = link[:active] %>
            <li>
              <%= link_to link[:path], class: [
                "group flex gap-x-3 rounded-md p-2 text-sm/6 font-semibold transition-colors",
                active ? "bg-gray-50 text-indigo-600 dark:bg-white/5 dark:text-white" : "text-gray-700 hover:bg-gray-50 hover:text-indigo-600 dark:text-gray-400 dark:hover:bg-white/5 dark:hover:text-white"
              ].join(" ") do %>
                <span class="flex size-6 shrink-0 items-center justify-center rounded-lg border text-[0.625rem] font-medium <%= active ? 'border-indigo-600 bg-indigo-50 text-indigo-600 dark:border-white/20 dark:bg-white/10 dark:text-white' : 'border-gray-200 bg-white text-gray-400 group-hover:border-indigo-600 group-hover:text-indigo-600 dark:border-white/15 dark:bg-white/5 dark:group-hover:border-white/20 dark:group-hover:text-white' %>">
                  <%= link[:label].to_s.first&.upcase %>
                </span>
                <span class="truncate"><%= link[:label] %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </li>

      <% if sidebar[:secondary_links].present? %>
        <li>
          <div class="text-xs/6 font-semibold text-gray-400"><%= sidebar[:secondary_title] %></div>
          <ul role="list" class="-mx-2 mt-2 space-y-1">
            <% sidebar[:secondary_links].each do |link| %>
              <% active = link[:active] %>
              <li>
                <%= link_to link[:path], class: [
                  "group flex gap-x-3 rounded-md p-2 text-sm/6 font-semibold transition-colors",
                  active ? "bg-gray-50 text-indigo-600 dark:bg-white/5 dark:text-white" : "text-gray-700 hover:bg-gray-50 hover:text-indigo-600 dark:text-gray-400 dark:hover:bg-white/5 dark:hover:text-white"
                ].join(" ") do %>
                  <span class="flex size-6 shrink-0 items-center justify-center rounded-lg border text-[0.625rem] font-medium <%= active ? 'border-indigo-600 bg-indigo-50 text-indigo-600 dark:border-white/20 dark:bg-white/10 dark:text-white' : 'border-gray-200 bg-white text-gray-400 group-hover:border-indigo-600 group-hover:text-indigo-600 dark:border-white/15 dark:bg-white/5 dark:group-hover:border-white/20 dark:group-hover:text-white' %>">
                    <%= link[:label].to_s.first&.upcase %>
                  </span>
                  <span class="truncate"><%= link[:label] %></span>
                <% end %>
              </li>
            <% end %>
          </ul>
        </li>
      <% end %>

      <li class="-mx-6 mt-auto">
        <div class="flex items-center gap-x-4 px-6 py-3 text-sm/6 font-semibold text-gray-900 dark:text-white">
          <%= image_tag current_user.avatar_url.present? ? current_user.avatar_url : "default_avatar.svg", alt: current_user.full_name, class: "size-8 rounded-full object-cover bg-gray-50 outline -outline-offset-1 outline-black/5 dark:bg-gray-800 dark:outline-white/10" %>
          <span class="truncate" aria-hidden="true"><%= current_user.full_name %></span>
        </div>
      </li>
    </ul>
  </nav>
</div>
